
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # API Gateway - force payment endpoints through the secure gateway function
  RewriteCond %{REQUEST_URI} ^/api/v1/health/?$
  RewriteRule ^api/v1/health/?$ https://fhwfonispezljglrclia.supabase.co/functions/v1/api-gateway/health [P,L]

  RewriteCond %{REQUEST_URI} ^/api/v1/payments/?$
  RewriteRule ^api/v1/payments/?$ https://fhwfonispezljglrclia.supabase.co/functions/v1/api-gateway/payments [P,L]

  RewriteCond %{REQUEST_URI} ^/api/v1/payments/(.*)$
  RewriteRule ^api/v1/payments/(.*)$ https://fhwfonispezljglrclia.supabase.co/functions/v1/api-gateway/payments/$1 [P,L]

  # Legacy API routes keep their existing direct mapping
  RewriteCond %{REQUEST_URI} ^/api/v1/(.*)$
  RewriteRule ^api/v1/(.*)$ https://fhwfonispezljglrclia.supabase.co/functions/v1/$1 [P,L]
  
  # SPA Fallback (only for non-API routes)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteRule . /index.html [L]
</IfModule>

# Enable proxy (required for [P] flag)
<IfModule mod_proxy.c>
  ProxyRequests Off
  ProxyPreserveHost On
</IfModule>
